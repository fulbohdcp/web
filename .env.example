# ── Supabase ──
# Get these from your Supabase project: Settings → API.
# Copy this file to .env.local (gitignored) and fill in real values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the client. Only needed for admin/server tasks.
# SUPABASE_SERVICE_ROLE_KEY=

# Base URL for OAuth redirects (e.g. http://localhost:3000 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" once the Google OAuth provider is configured in Supabase.
# While unset/false, the "Continuar con Google" button shows disabled ("Pronto").
NEXT_PUBLIC_GOOGLE_ENABLED=

# ── Mapbox (zona / búsqueda por cercanía) ──
# Public token from https://account.mapbox.com/access-tokens/ (free tier).
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Resend (envío de mails de la app, ej. invitaciones) ──
# RESEND_API_KEY=
